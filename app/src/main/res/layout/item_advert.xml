<?xml version="1.0" encoding="utf-8"?>

<!-- Single item card used inside RecyclerView -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:background="@drawable/bg_card"
    android:layout_marginBottom="12dp">

    <!-- Item image thumbnail -->
    <ImageView
        android:id="@+id/imgItem"
        android:layout_width="92dp"
        android:layout_height="92dp"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_image_box"
        android:src="@android:drawable/ic_menu_gallery" />

    <!-- Text area beside image -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="14dp">

        <!-- Lost/Found title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lost: Wallet"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:maxLines="1" />

        <!-- Category -->
        <TextView
            android:id="@+id/tvCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Category: Wallets"
            android:textSize="14sp"
            android:textColor="#4B5563"
            android:layout_marginTop="6dp"
            android:maxLines="1" />

        <!-- Location -->
        <TextView
            android:id="@+id/tvLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Location: Melbourne"
            android:textSize="14sp"
            android:textColor="#4B5563"
            android:layout_marginTop="4dp"
            android:maxLines="1" />

        <!-- Timestamp -->
        <TextView
            android:id="@+id/tvDateTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Posted: 07 May 2026"
            android:textSize="13sp"
            android:textColor="#6B7280"
            android:layout_marginTop="6dp"
            android:maxLines="1" />

    </LinearLayout>

</LinearLayout>