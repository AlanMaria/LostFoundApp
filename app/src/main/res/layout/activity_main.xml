<?xml version="1.0" encoding="utf-8"?>

<!-- Home screen of the Lost & Found app -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@drawable/bg_screen">

    <!-- App icon style image -->
    <TextView
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:gravity="center"
        android:text="🔎"
        android:textSize="44sp"
        android:background="@drawable/bg_card"
        android:layout_marginBottom="22dp" />

    <!-- App title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lost &amp; Found"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#111827"
        android:layout_marginBottom="8dp" />

    <!-- App subtitle -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Post lost or found items and help return them to the right owner."
        android:textSize="16sp"
        android:textColor="#6B7280"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="38dp" />

    <!-- Button to create a new advert -->
    <Button
        android:id="@+id/btnCreateAdvert"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:text="Create New Advert"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_primary_button"
        android:layout_marginBottom="16dp" />

    <!-- Button to view saved adverts -->
    <Button
        android:id="@+id/btnShowItems"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:text="Show Lost &amp; Found Items"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_secondary_button" />

</LinearLayout>