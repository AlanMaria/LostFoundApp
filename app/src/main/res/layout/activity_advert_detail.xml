<?xml version="1.0" encoding="utf-8"?>

<!-- Detail screen for one selected advert -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Page title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Advert Details"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:layout_marginBottom="4dp" />

        <!-- Page subtitle -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View the full details and remove the advert once resolved."
            android:textSize="15sp"
            android:textColor="#6B7280"
            android:layout_marginBottom="16dp" />

        <!-- Main details card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/bg_card">

            <!-- Large item image -->
            <ImageView
                android:id="@+id/imgDetail"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_image_box"
                android:src="@android:drawable/ic_menu_gallery"
                android:layout_marginBottom="18dp" />

            <!-- Full advert information -->
            <TextView
                android:id="@+id/tvDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Details will appear here"
                android:textSize="16sp"
                android:textColor="#1F2937"
                android:lineSpacingExtra="6dp"
                android:layout_marginBottom="20dp" />

            <!-- Remove advert button -->
            <Button
                android:id="@+id/btnRemove"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Remove Advert"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_secondary_button" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>